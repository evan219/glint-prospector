# Glint Solar credentials
GLINT_EMAIL=your@email.com
GLINT_PASSWORD=yourpassword

# Target bounding box (lat/lon) — define before running tile enumeration
# Example: Allegany County, NY area
BBOX_LAT_MIN=42.00
BBOX_LAT_MAX=42.30
BBOX_LON_MIN=-78.10
BBOX_LON_MAX=-77.70

# Tile zoom level (13 recommended — ~10-20 sq km per tile)
TILE_ZOOM=13

# Phase 1: Parcel discovery starting point
PORTFOLIO_URL=
COORDINATE_START=42.665194, -78.704382

# Phase 3: Installed Capacity — project URL and DOM selectors
# Create a project in the Glint app, add parcels, then paste the project URL here.
PROJECT_URL=
SEL_NEW_ANALYSIS=
SEL_CAPACITY_KW=
