# Glint Solar credentials
GLINT_EMAIL=your@email.com
GLINT_PASSWORD=yourpassword

# Target bounding box (lat/lon) — define before running tile enumeration
# Example: Allegany County, NY area
BBOX_LAT_MIN=42.00
BBOX_LAT_MAX=42.30
BBOX_LON_MIN=-78.10
BBOX_LON_MAX=-77.70

# Tile zoom level (13 recommended — ~10-20 sq km per tile)
TILE_ZOOM=13
